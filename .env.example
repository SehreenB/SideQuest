# ── Google AI ──────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here

# ── Vultr Object Storage (S3-compatible) ───────────────────
VULTR_ACCESS_KEY=your_vultr_access_key
VULTR_SECRET_KEY=your_vultr_secret_key
VULTR_ENDPOINT=https://ewr1.vultrobjects.com   # change region as needed
VULTR_BUCKET=sidequest-uploads
VULTR_REGION=ewr1

# ── Solana ─────────────────────────────────────────────────
# Base58 private key array for the fee-payer / tree authority wallet
SOLANA_PRIVATE_KEY=[1,2,3,...]   # replace with your keypair byte array

# ── Server ─────────────────────────────────────────────────
PORT=3000
